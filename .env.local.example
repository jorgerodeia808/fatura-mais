# ================================================================
# Fatura+ — Variáveis de Ambiente
# Copia este ficheiro para .env.local e preenche os valores reais
# NUNCA coloques .env.local no controlo de versões (git)
# ================================================================

# ── Supabase ──────────────────────────────────────────────────────
# Obtém em: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Anthropic (Conselheiro IA) ────────────────────────────────────
# Obtém em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Resend (notificações por email) ──────────────────────────────
# Obtém em: https://resend.com/api-keys
RESEND_API_KEY=re_...

# ── Twilio (SMS automáticos) ──────────────────────────────────────
# Obtém em: https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+351XXXXXXXXX

# ── App ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://fatura-mais.pt

# ── Cron (segredo para proteger endpoints do cron job) ────────────
# Gera um valor: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=SUBSTITUI_POR_UM_SEGREDO_ALEATORIO
